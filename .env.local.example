# Supabase project URL — found in: Supabase Dashboard > Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key — found in: Supabase Dashboard > Settings > API > service_role (secret)
# WARNING: This key bypasses Row-Level Security and must ONLY be used in server-side code
# (API route handlers, server components). Never expose it to the browser or commit it to source control.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
